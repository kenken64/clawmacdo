# Dry-run mode (simulated deploys, no real cloud API calls)
CLAWMACDO_DRY_RUN=false

# GitHub token for repository operations
GH_TOKEN=

# AI provider API keys
ANTHROPIC_API_KEY=
ANTHROPIC_SETUP_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security scan output format (json, text, sarif)
FORMAT=json

# API key database path (defaults to ./keys.db)
KEY_DB=
